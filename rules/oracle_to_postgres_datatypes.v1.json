{
  "ruleset": {
    "id": "oracle_to_postgres_datatypes",
    "version": "1.0.0",
    "sourceEngine": "oracle",
    "targetEngine": "postgresql",
    "targetVersionRange": "15-18",
    "status": "draft",
    "principle": "Rules are deterministic first. Use AI only after rules classify an object as complex, ambiguous, or manual-review-heavy."
  },
  "automationClasses": {
    "AUTO_SAFE": "Generated mapping can be deployed after syntax/dependency validation.",
    "AUTO_REVIEW": "Generated mapping is useful, but migration engineer approval is required.",
    "MANUAL_REQUIRED": "Detection is deterministic, but safe conversion requires design input.",
    "BLOCKER": "Migration cannot proceed until the issue is resolved."
  },
  "officialReferences": {
    "postgres": {
      "dataTypes": "https://www.postgresql.org/docs/current/datatype.html",
      "numeric": "https://www.postgresql.org/docs/current/datatype-numeric.html",
      "character": "https://www.postgresql.org/docs/current/datatype-character.html",
      "binary": "https://www.postgresql.org/docs/current/datatype-binary.html",
      "dateTime": "https://www.postgresql.org/docs/current/datatype-datetime.html",
      "dateTimeFunctions": "https://www.postgresql.org/docs/current/functions-datetime.html",
      "json": "https://www.postgresql.org/docs/current/datatype-json.html",
      "xml": "https://www.postgresql.org/docs/current/datatype-xml.html",
      "uuid": "https://www.postgresql.org/docs/current/datatype-uuid.html",
      "arrays": "https://www.postgresql.org/docs/current/arrays.html"
    },
    "oracle": {
      "dataTypes": "https://docs.oracle.com/en/database/oracle/oracle-database/23/sqlrf/Data-Types.html"
    }
  },
  "rules": [
    {
      "ruleCode": "DT_NUM_001",
      "sourcePattern": "NUMBER(p,0) where p <= 4",
      "targetType": "smallint",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["precision", "scale", "min_value", "max_value"],
      "reviewRequiredWhen": ["column stores codes with values outside smallint range", "application binds as numeric"],
      "recommendation": "Use smallint only when profiled values fit PostgreSQL smallint range; otherwise promote to integer or numeric(p,0).",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_002",
      "sourcePattern": "NUMBER(p,0) where p between 5 and 9",
      "targetType": "integer",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["precision", "scale", "min_value", "max_value"],
      "reviewRequiredWhen": ["profiled values exceed integer range", "application binds as numeric"],
      "recommendation": "Use integer only when profiled values fit PostgreSQL integer range; otherwise promote to bigint or numeric(p,0).",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_003",
      "sourcePattern": "NUMBER(p,0) where p between 10 and 18",
      "targetType": "bigint",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["precision", "scale", "min_value", "max_value", "sequence_usage"],
      "reviewRequiredWhen": ["profiled values exceed bigint range", "column is used with unbounded Oracle NUMBER APIs"],
      "recommendation": "Use bigint for integer identifiers only when range evidence is safe; keep numeric(p,0) for exact Oracle NUMBER compatibility.",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_004",
      "sourcePattern": "NUMBER(p,0) where p > 18",
      "targetType": "numeric(p,0)",
      "automationClass": "AUTO_SAFE",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["precision", "scale"],
      "reviewRequiredWhen": ["used in joins against integer/bigint columns", "used as function argument against bigint columns"],
      "recommendation": "Preserve exact precision with numeric(p,0); separately flag implicit-cast performance risks.",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_005",
      "sourcePattern": "NUMBER(p,s) where s > 0",
      "targetType": "numeric(p,s)",
      "automationClass": "AUTO_SAFE",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["precision", "scale"],
      "reviewRequiredWhen": ["precision is very high and column is high-volume or heavily aggregated"],
      "recommendation": "Preserve exact decimal semantics with numeric(p,s); performance review may be needed for high precision analytics.",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_006",
      "sourcePattern": "NUMBER without precision or scale",
      "targetType": "numeric",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["min_value", "max_value", "fractional_scale_profile", "bind_type_profile"],
      "reviewRequiredWhen": ["column participates in PK/FK joins", "application expects integer behavior", "high-volume arithmetic"],
      "recommendation": "Default to numeric for correctness, but profile values to downcast safely to bigint/integer/numeric(p,s).",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_007",
      "sourcePattern": "NUMBER(1)",
      "targetType": "boolean or smallint",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["distinct_values", "check_constraints", "column_name_semantics"],
      "reviewRequiredWhen": ["values are not strictly 0/1", "application treats column as code not boolean"],
      "recommendation": "Map to boolean only when data and constraints prove 0/1 flag semantics; otherwise use smallint or numeric(1,0).",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_NUM_008",
      "sourcePattern": "FLOAT, BINARY_FLOAT, BINARY_DOUBLE",
      "targetType": "double precision or real",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["source_type", "precision", "comparison_usage"],
      "reviewRequiredWhen": ["used in equality comparisons", "used for money/financial values"],
      "recommendation": "Map BINARY_FLOAT to real and BINARY_DOUBLE to double precision; review Oracle FLOAT precision semantics before choosing numeric or double precision.",
      "referenceKeys": ["postgres.numeric", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_001",
      "sourcePattern": "VARCHAR2(n CHAR)",
      "targetType": "varchar(n)",
      "automationClass": "AUTO_SAFE",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["length_semantics"],
      "reviewRequiredWhen": ["application relies on Oracle empty string equals NULL behavior"],
      "recommendation": "Map character-length VARCHAR2 to varchar(n); add separate NULL/empty-string semantic checks.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_002",
      "sourcePattern": "VARCHAR2(n BYTE)",
      "targetType": "varchar(n) or text with check",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["length_semantics", "database_charset", "max_octet_length_profile"],
      "reviewRequiredWhen": ["database uses multibyte characters", "application enforces byte length"],
      "recommendation": "PostgreSQL varchar(n) counts characters, not Oracle BYTE semantics; use a byte-length check when byte enforcement matters.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_003",
      "sourcePattern": "CHAR(n)",
      "targetType": "char(n)",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["trailing_space_usage", "comparison_usage"],
      "reviewRequiredWhen": ["application relies on blank padding behavior", "joins compare char to varchar/text"],
      "recommendation": "Map to char(n) for storage semantics, but review trailing-space comparison behavior and index predicates.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_004",
      "sourcePattern": "NVARCHAR2, NCHAR",
      "targetType": "varchar(n) or char(n)",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["national_charset", "collation_requirements", "length_semantics"],
      "reviewRequiredWhen": ["locale-specific sorting/search is required", "application depends on national character set behavior"],
      "recommendation": "PostgreSQL database encoding is usually UTF-8; map to varchar/char and attach collation review.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_005",
      "sourcePattern": "CLOB, NCLOB",
      "targetType": "text",
      "automationClass": "AUTO_REVIEW",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["lob_size_profile", "lob_api_usage"],
      "reviewRequiredWhen": ["application uses Oracle LOB locator APIs", "very large LOB streaming is required"],
      "recommendation": "Map CLOB/NCLOB to text for SQL semantics; review application LOB streaming and storage strategy.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_CHR_006",
      "sourcePattern": "LONG",
      "targetType": "text",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["column_usage", "data_size_profile"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "LONG is legacy Oracle behavior; convert to text with manual review and application/API testing.",
      "referenceKeys": ["postgres.character", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_BIN_001",
      "sourcePattern": "RAW(n)",
      "targetType": "bytea",
      "automationClass": "AUTO_SAFE",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["max_length"],
      "reviewRequiredWhen": ["column stores GUIDs that should become uuid"],
      "recommendation": "Map RAW to bytea; detect 16-byte GUID-like columns as a separate UUID review rule.",
      "referenceKeys": ["postgres.binary", "postgres.uuid", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_BIN_002",
      "sourcePattern": "BLOB",
      "targetType": "bytea or object storage reference",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["lob_size_profile", "lob_api_usage", "access_pattern"],
      "reviewRequiredWhen": ["large streaming objects", "application uses Oracle LOB locators"],
      "recommendation": "Use bytea for ordinary binary payloads; use object storage/reference pattern for very large content or streaming workloads.",
      "referenceKeys": ["postgres.binary", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_BIN_003",
      "sourcePattern": "BFILE",
      "targetType": "external file reference",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["directory_objects", "file_path_policy", "application_access_pattern"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "BFILE points outside the database; design a replacement using object storage or managed file references.",
      "referenceKeys": ["postgres.binary", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_001",
      "sourcePattern": "DATE",
      "targetType": "timestamp without time zone",
      "automationClass": "AUTO_REVIEW",
      "confidence": "HIGH",
      "severity": "WARNING",
      "requiresEvidence": ["timezone_policy", "time_component_profile", "default_expression"],
      "reviewRequiredWhen": ["application expects timezone normalization", "column is date-only by business meaning", "SYSDATE behavior matters"],
      "recommendation": "Oracle DATE stores date and time without timezone; map to PostgreSQL timestamp by default, not timestamptz.",
      "referenceKeys": ["postgres.dateTime", "postgres.dateTimeFunctions", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_002",
      "sourcePattern": "TIMESTAMP",
      "targetType": "timestamp without time zone",
      "automationClass": "AUTO_SAFE",
      "confidence": "HIGH",
      "severity": "INFO",
      "requiresEvidence": ["fractional_seconds_precision"],
      "reviewRequiredWhen": ["precision policy differs", "application expects timezone conversion"],
      "recommendation": "Preserve no-timezone timestamp semantics and fractional precision where required.",
      "referenceKeys": ["postgres.dateTime", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_003",
      "sourcePattern": "TIMESTAMP WITH TIME ZONE",
      "targetType": "timestamp with time zone",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["timezone_region_usage", "session_timezone_policy"],
      "reviewRequiredWhen": ["Oracle stores named timezone regions", "display timezone semantics must be preserved"],
      "recommendation": "Map to timestamptz for instant-in-time semantics; review named timezone region behavior and display expectations.",
      "referenceKeys": ["postgres.dateTime", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_004",
      "sourcePattern": "TIMESTAMP WITH LOCAL TIME ZONE",
      "targetType": "timestamp with time zone or timestamp without time zone",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["database_timezone", "session_timezone_usage", "application_display_policy"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "Oracle local-time-zone semantics are application-visible; choose timestamptz or timestamp only after timezone policy review.",
      "referenceKeys": ["postgres.dateTime", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_005",
      "sourcePattern": "INTERVAL YEAR TO MONTH",
      "targetType": "interval",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["interval_precision", "arithmetic_usage"],
      "reviewRequiredWhen": ["application depends on exact month arithmetic edge cases"],
      "recommendation": "PostgreSQL interval supports months, but month arithmetic must be tested for edge cases.",
      "referenceKeys": ["postgres.dateTime", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_TMP_006",
      "sourcePattern": "INTERVAL DAY TO SECOND",
      "targetType": "interval",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["fractional_seconds_precision", "arithmetic_usage"],
      "reviewRequiredWhen": ["fractional precision must be exact", "application depends on formatting"],
      "recommendation": "Map to interval and validate arithmetic plus formatting behavior.",
      "referenceKeys": ["postgres.dateTime", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_ROW_001",
      "sourcePattern": "ROWID, UROWID",
      "targetType": "text",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["application_rowid_usage", "stored_rowid_columns"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "Oracle ROWID has no stable PostgreSQL equivalent; redesign code to use primary keys or generated surrogate identifiers.",
      "referenceKeys": ["postgres.dataTypes", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_XML_001",
      "sourcePattern": "XMLTYPE",
      "targetType": "xml or text",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["xml_query_usage", "schema_validation_usage", "index_usage"],
      "reviewRequiredWhen": ["Oracle XML DB features are used", "XPath/XQuery behavior matters"],
      "recommendation": "Map simple stored XML to xml or text; Oracle XML DB feature usage requires manual review.",
      "referenceKeys": ["postgres.xml", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_JSON_001",
      "sourcePattern": "JSON stored in CLOB/VARCHAR2/BLOB or Oracle JSON type",
      "targetType": "jsonb or json",
      "automationClass": "AUTO_REVIEW",
      "confidence": "MEDIUM",
      "severity": "WARNING",
      "requiresEvidence": ["json_validity", "duplicate_key_policy", "query_index_usage"],
      "reviewRequiredWhen": ["duplicate key preservation matters", "whitespace/order preservation matters", "application uses Oracle JSON operators"],
      "recommendation": "Prefer jsonb for querying and indexing; use json when preserving textual representation matters.",
      "referenceKeys": ["postgres.json", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_SPA_001",
      "sourcePattern": "SDO_GEOMETRY",
      "targetType": "geometry/geography via PostGIS or jsonb/text",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["spatial_index_usage", "geometry_types", "target_extension_policy"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "Requires target extension and spatial feature design; no no-extension PostgreSQL core equivalent exists.",
      "referenceKeys": ["postgres.dataTypes", "oracle.dataTypes"]
    },
    {
      "ruleCode": "DT_UDT_001",
      "sourcePattern": "OBJECT TYPE, VARRAY, NESTED TABLE",
      "targetType": "composite type, array, jsonb, or normalized tables",
      "automationClass": "MANUAL_REQUIRED",
      "confidence": "LOW",
      "severity": "CRITICAL",
      "requiresEvidence": ["type_definition", "method_usage", "collection_usage", "sql_usage"],
      "reviewRequiredWhen": ["always"],
      "recommendation": "Oracle object-relational features need design-level conversion, usually to normalized tables or jsonb.",
      "referenceKeys": ["postgres.arrays", "postgres.json", "oracle.dataTypes"]
    }
  ]
}
