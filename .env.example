# Synqora local/internal control-plane database configuration.
#
# Phase 1 local default:
# - memory storage is useful for UI demos only.
# - internal_postgres is the preferred local/product-development metadata store.
#
# Later cloud direction:
# - keep SYNQORA_STORAGE=internal_postgres/postgres semantics.
# - point SYNQORA_DATABASE_URL at managed PostgreSQL, Aurora PostgreSQL, Cloud SQL, AlloyDB, etc.

# memory | internal_postgres | postgres
SYNQORA_STORAGE=internal_postgres

# Option A: database name resolved by local psql environment.
SYNQORA_DB_NAME=postgres

# Option B: full managed/internal PostgreSQL URL.
# SYNQORA_DATABASE_URL=postgresql://synqora_app:change-me@127.0.0.1:5432/synqora_control

SYNQORA_HOST=127.0.0.1
SYNQORA_PORT=8787

# Demo-only credentials for local prototype auth.
SYNQORA_DEMO_EMAIL=sai@example.com
SYNQORA_DEMO_PASSWORD=Synqora_123
